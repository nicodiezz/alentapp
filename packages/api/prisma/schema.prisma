// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

enum PaymentStatus {
    Pending
    Paid
    Canceled
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    
    equipment_loans     EquipmentLoan[]
    medical_certificates MedicalCertificate[]
    disciplines         Discipline[]
    payments            Payment[]
    lockers             Locker[]
    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}


model Payment {
    id              String @id @default(uuid())
    member_id       String
    amount          Float
    month           Int
    year            Int
    status          PaymentStatus
    due_date        DateTime @db.Date
    payment_date    DateTime? @db.Date
    created_at      DateTime @default(now())
    member          Member @relation(fields: [member_id], references: [id])
    @@map("payments")  
}


model Discipline {
    id                  String   @id @default(uuid())
    reason              String
    issue_date          DateTime @db.Date
    expiry_date         DateTime @db.Date
    is_total_suspension Boolean
    created_at          DateTime @default(now())

    member_id           String
    member              Member   @relation(fields: [member_id], references: [id])

    @@map("disciplines")
}

model Sport {
    id                           String   @id @default(uuid())
    name                         String   @unique
    description                  String
    max_capacity                 Int
    additional_price             Decimal
    requires_medical_certificate Boolean

    @@map("sports")
}

model MedicalCertificate {
    id             String     @id @default(uuid())
    issue_date     DateTime   @db.Date
    expiry_date    DateTime   @db.Date
    doctor_license String
    is_validated   Boolean    @default(false)

    member_id      String
    member         Member     @relation(fields: [member_id], references: [id])

    @@map("medical_certificates")
}

enum EquipmentLoanStatus {
    Loaned
    Returned
    Damaged
}

enum LockerStatus {
    Available
    Occupied
    Maintenance
}

model EquipmentLoan {
    id             String     @id @default(uuid())
    item_name      String
    status         EquipmentLoanStatus
    loan_date     DateTime   @db.Date
    due_date    DateTime   @db.Date
    member_id      String
    member         Member     @relation(fields: [member_id], references: [id])

    @@map("equipment_loans")
}

model Locker {
    id        String       @id @default(uuid())
    number    Int          @unique
    location  String
    status    LockerStatus @default(Available)
    member_id String?
    member    Member?      @relation(fields: [member_id], references: [id])

    @@index([number])
    @@map("lockers")
}
